# Pinecone — required for the vector / runtime layer. Get a key: https://app.pinecone.io
# Copy this file to `.env` and fill in the value. `.env` is gitignored — never commit real keys.
PINECONE_API_KEY=

# Optional — index name the brain uses (defaults to "agent-brain")
# AGENT_BRAIN_INDEX=agent-brain

# Optional — integrated-embedding model (defaults to "llama-text-embed-v2").
# Override for a different Pinecone account/region/model availability.
# AGENT_BRAIN_EMBED_MODEL=llama-text-embed-v2

# Required — path to the external, git-backed brain-store repo that holds the
# raw episode tier and the distilled L2 knowledge nodes. Must be a git working
# tree that lives outside (and does not contain) this public repo's working
# tree — agent-brain refuses to start otherwise. Personal content never lands
# in this repo.
AGENT_BRAIN_STORE=
